# AI Stack Hub — Server API

# Server
PORT=3000
NODE_ENV=production

# Database (PostgreSQL)
DATABASE_URL="postgresql://user:password@localhost:5432/ai_stack_hub?schema=public"

# JWT
JWT_SECRET="change-this-to-a-random-secret-string"
JWT_EXPIRES_IN="7d"

# CORS (comma-separated origins)
CORS_ORIGIN="https://your-frontend.vercel.app,https://your-admin.netlify.app"
