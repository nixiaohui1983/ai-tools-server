# AI Stack Hub — Server API
# 本地开发: 直接使用此文件
# Render 部署: 环境变量由 render.yaml 自动注入，不需要此文件

# Server
PORT=3000
NODE_ENV=development

# Database (PostgreSQL)
# 本地: localhost PostgreSQL
# Render: 创建 PostgreSQL 后自动注入 DATABASE_URL
DATABASE_URL="postgresql://user:password@localhost:5432/ai_stack_hub?schema=public"

# JWT (本地开发默认值，生产环境请使用 render.yaml 中的 generateValue)
JWT_SECRET="change-this-to-a-random-secret-string"
JWT_EXPIRES_IN="7d"

# CORS (逗号分隔)
CORS_ORIGIN="http://localhost:3001,http://localhost:5173"
